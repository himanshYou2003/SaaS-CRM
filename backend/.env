APP_NAME="SaaS CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── MongoDB ───────────────────────────────────────────────────────────────────
DB_CONNECTION=mongodb+srv://multi-tenant:multi-tenant@cluster0.dwahuvp.mongodb.net/?appName=Cluster0
DB_HOST=mongo
DB_PORT=27017
DB_DATABASE=crm_db
DB_USERNAME=crm_user
DB_PASSWORD=crm_secret
MONGODB_AUTH_SOURCE=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=crm_redis_secret
REDIS_PORT=6379

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@saascrm.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

# ── Horizon ───────────────────────────────────────────────────────────────────
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# ── Swagger ───────────────────────────────────────────────────────────────────
L5_SWAGGER_GENERATE_ALWAYS=true
